# Copy to .env (gitignored) and fill in. NEVER commit a real key.
#   cp .env.example .env

# Which backend the gateway uses. Only "claude" is implemented today;
# "ollama" is the planned local backend (P3-05).
LLM_BACKEND=claude

# Anthropic API key (owner's personal account). Required for the claude backend.
ANTHROPIC_API_KEY=

# Live model. Switch this + restart to change Vector's brain -- no wire-pod change.
#   claude-haiku-4-5  -> fastest / cheapest, good for short spoken answers (default)
#   claude-opus-4-8   -> richer answers
CLAUDE_MODEL=claude-haiku-4-5

# Max output tokens (spoken answers are short; also bounds cost/latency).
MAX_TOKENS=1024

# Port the gateway listens on (wire-pod's endpoint points here).
GATEWAY_PORT=8088
